# Server Configuration
PORT=8001

# Storage Configuration
STORAGE_TYPE=r2

# R2 Configuration
R2_BUCKET_NAME=your_bucket_name
R2_BASE_PATH=
WHISPER_ENGINE=mlx-whisper

# AI Provider Configuration
# OpenAI API (for GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Configuration
# Option 1: Google AI Studio API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Gemini Local Proxy (optional)
GEMINI_LOCAL_ENDPOINT=http://localhost:5568

# AI Provider Selection (openai | gemini)
AI_PROVIDER=gemini

# SQS Auto Processing Configuration
SQS_AUTO_SEGMENT=false           # Auto segment after transcription (true/false)
SQS_AUTO_TRANSLATE=false         # Auto translate after segmentation (true/false)
SQS_AUTO_LANGUAGE_ANALYSIS=false # Auto language analysis after transcription (true/false)
SQS_TARGET_LANGUAGES=            # Target languages for translation (comma-separated, e.g., zh-TW,ja,ko)
SQS_SEGMENT_COUNT=6              # Target number of segments
SQS_AI_SERVICE=gemini            # AI service for segmentation/translation/analysis (gemini/openai)
