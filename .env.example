# Server Configuration
PORT=8001

# R2 Configuration
R2_BUCKET_NAME=your-r2-bucket-name

# Note: R2 authentication is handled via AWS CLI with 'cloudflare' profile
# Make sure you have configured: aws configure --profile cloudflare
# And set up the alias: alias r2='aws --profile cloudflare s3'
# 
# SRT files will be uploaded to: s3://bucket/videoId/language/videoId.srt
# Example: s3://my-bucket/dQw4w9WgXcQ/default/dQw4w9WgXcQ.srt